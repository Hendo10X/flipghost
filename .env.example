# Neon serverless Postgres connection string
DATABASE_URL="postgresql://user:password@your-project.neon.tech/flipghost?sslmode=require"

# better-auth (generate with: bunx @better-auth/cli secret)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (console.cloud.google.com -> APIs & Services -> Credentials)
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Marble CMS, which backs /blog, /changelog and /tutorials.
# Key: marblecms.com dashboard -> Settings -> API Keys.
# Without it those three pages build and render their empty state, so this is
# only needed once there is something published to show.
MARBLE_API_KEY=""

# Shared secret for the Marble webhook that refreshes those pages on publish.
# Invent any long random string, then paste the same value into
# Settings -> Webhooks with the URL https://<your-domain>/api/marble/revalidate
# Leave blank to skip webhooks; pages still refresh on their own every 5 minutes.
MARBLE_WEBHOOK_SECRET=""
